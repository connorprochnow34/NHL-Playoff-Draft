generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum DraftStatus {
  PENDING
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

enum SeriesStatus {
  UPCOMING
  IN_PROGRESS
  COMPLETED
}

model User {
  id          String   @id @default(uuid()) @db.Uuid
  email       String   @unique
  displayName String   @map("display_name")
  avatarUrl   String?  @map("avatar_url")
  createdAt   DateTime @default(now()) @map("created_at")

  commissionerOf Group[]       @relation("commissioner")
  memberships    GroupMember[]
  picks          Pick[]
  points         Point[]

  @@map("users")
}

model Group {
  id               String      @id @default(uuid()) @db.Uuid
  name             String
  commissionerId   String      @map("commissioner_id") @db.Uuid
  commissioner     User        @relation("commissioner", fields: [commissionerId], references: [id])
  inviteCode       String      @unique @map("invite_code") @db.VarChar(6)
  draftStatus      DraftStatus @default(PENDING) @map("draft_status")
  draftScheduledAt DateTime?   @map("draft_scheduled_at")
  draftNotes       String?     @map("draft_notes")
  pickTimerSeconds Int         @default(60) @map("pick_timer_seconds")
  createdAt        DateTime    @default(now()) @map("created_at")

  members GroupMember[]
  picks   Pick[]
  points  Point[]

  @@map("groups")
}

model GroupMember {
  id            String   @id @default(uuid()) @db.Uuid
  groupId       String   @map("group_id") @db.Uuid
  group         Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId        String   @map("user_id") @db.Uuid
  user          User     @relation(fields: [userId], references: [id])
  draftPosition Int?     @map("draft_position")
  joinedAt      DateTime @default(now()) @map("joined_at")

  @@unique([groupId, userId])
  @@map("group_members")
}

model NhlTeam {
  id            String   @id @default(uuid()) @db.Uuid
  nhlApiId      Int      @unique @map("nhl_api_id")
  name          String
  abbreviation  String
  logoUrl       String   @map("logo_url")
  darkLogoUrl   String?  @map("dark_logo_url")
  conference    String
  division      String
  seed          Int?
  isPlayoffTeam Boolean  @default(false) @map("is_playoff_team")
  createdAt     DateTime @default(now()) @map("created_at")

  homeSeries Series[] @relation("hometeam")
  awaySeries Series[] @relation("awayteam")
  wonSeries  Series[] @relation("winner")
  picks      Pick[]
  points     Point[]

  @@map("nhl_teams")
}

model Series {
  id           String       @id @default(uuid()) @db.Uuid
  round        Int
  seriesLetter String       @unique @map("series_letter")
  homeTeamId   String       @map("home_team_id") @db.Uuid
  homeTeam     NhlTeam      @relation("hometeam", fields: [homeTeamId], references: [id])
  awayTeamId   String       @map("away_team_id") @db.Uuid
  awayTeam     NhlTeam      @relation("awayteam", fields: [awayTeamId], references: [id])
  homeSeed     Int          @map("home_seed")
  awaySeed     Int          @map("away_seed")
  winnerTeamId String?      @map("winner_team_id") @db.Uuid
  winner       NhlTeam?     @relation("winner", fields: [winnerTeamId], references: [id])
  homeWins     Int          @default(0) @map("home_wins")
  awayWins     Int          @default(0) @map("away_wins")
  status       SeriesStatus @default(UPCOMING)
  nhlSeriesId  String?      @map("nhl_series_id")
  createdAt    DateTime     @default(now()) @map("created_at")

  points Point[]

  @@map("series")
}

model Pick {
  id            String   @id @default(uuid()) @db.Uuid
  groupId       String   @map("group_id") @db.Uuid
  group         Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId        String   @map("user_id") @db.Uuid
  user          User     @relation(fields: [userId], references: [id])
  teamId        String   @map("team_id") @db.Uuid
  team          NhlTeam  @relation(fields: [teamId], references: [id])
  draftRound    Int      @map("draft_round")
  draftPosition Int      @map("draft_position")
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([groupId, teamId])
  @@map("picks")
}

model Point {
  id            String   @id @default(uuid()) @db.Uuid
  groupId       String   @map("group_id") @db.Uuid
  group         Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId        String   @map("user_id") @db.Uuid
  user          User     @relation(fields: [userId], references: [id])
  seriesId      String   @map("series_id") @db.Uuid
  series        Series   @relation(fields: [seriesId], references: [id])
  teamId        String   @map("team_id") @db.Uuid
  team          NhlTeam  @relation(fields: [teamId], references: [id])
  pointsAwarded Int      @map("points_awarded")
  wasUnderdog   Boolean  @map("was_underdog")
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([groupId, seriesId, teamId])
  @@map("points")
}

model SyncLog {
  id       String   @id @default(uuid()) @db.Uuid
  syncedAt DateTime @default(now()) @map("synced_at")
  status   String
  details  String?

  @@map("sync_log")
}
